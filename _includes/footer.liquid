{% if site.footer_fixed %}
  {% comment %}<footer class="fixed-bottom" role="contentinfo">{% endcomment %}
{% comment %}{% endcomment %}
  {% comment %}</footer>{% endcomment %}
{% else %}
  {% comment %}<footer class="sticky-bottom mt-5" role="contentinfo">{% endcomment %}
{% comment %}{% endcomment %}
  {% comment %}</footer>{% endcomment %}
{% endif %}
